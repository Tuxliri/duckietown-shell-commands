#!/usr/bin/env bash

set -x

SD_DEVICE=/dev/sda1
ROOT_PART_ID=1
CONFIG_DIR=/data/config
EVENTS_DIR=/data/stats/events
USAGE_DIR=/data/stats/usage
ROBOT_TYPE_FILE=${CONFIG_DIR}/robot_type
ROBOT_HARDWARE_FILE=${CONFIG_DIR}/robot_hardware

detect_root_blockdevs() {
  ROOT_DEV="$(findmnt -n -o SOURCE /)"          # e.g. /dev/mmcblk0p1 or /dev/sda1
  ROOT_DISK="/dev/$(lsblk -no PKNAME "$ROOT_DEV")"  # e.g. /dev/mmcblk0 or /dev/sda
  ROOT_PART="$ROOT_DEV"

  echo "Detected root: ROOT_DISK=$ROOT_DISK ROOT_PART=$ROOT_PART"
}

safe_grow_rootfs() {
  # Run in subshell to contain set -euo pipefail
  (
    set -euo pipefail

    detect_root_blockdevs

    # Only ext4
    FSTYPE="$(findmnt -n -o FSTYPE /)"
    if [ "$FSTYPE" != "ext4" ]; then
      echo "safe_grow_rootfs: root fstype=$FSTYPE, skipping"
      exit 0
    fi

    # Partition number from /dev/mmcblk0p1 or /dev/sda1 -> 1
    PART_NUM="$(echo "$ROOT_PART" | grep -oE '[0-9]+$')"

    echo "safe_grow_rootfs: Fix GPT backup header and grow partition if needed..."
    sgdisk --move-second-header "$ROOT_DISK" || true
    partprobe "$ROOT_DISK" || true
    growpart "$ROOT_DISK" "$PART_NUM" || true
    partprobe "$ROOT_DISK" || true

    echo "safe_grow_rootfs: Resizing filesystem (online)..."
    resize2fs "$ROOT_PART"

    echo "safe_grow_rootfs: done"
  )
}

enable_cameras() {
    echo "=== Enabling cameras ==="

    # config-by-hardware.py searches /boot/dtb/ for a DTB whose embedded
    # 'compatible' matches the running board. On some board variants (e.g. the
    # Orin Nano Super, p3767-0005) only /boot/*.dtb exists but not /boot/dtb/*.dtb.
    # Detect and copy the matching DTB over before calling the tool.
    BOARD_COMPAT="$(cat /proc/device-tree/compatible | tr '\000' '\n' | head -1)"
    echo "Board compatible: ${BOARD_COMPAT}"

    DTB_FOUND=""
    for dtb in /boot/*.dtb; do
        if [ "$(fdtget "$dtb" / compatible 2>/dev/null | awk '{print $1}')" = "${BOARD_COMPAT}" ]; then
            DTB_FOUND="$dtb"
            break
        fi
    done

    if [ -n "$DTB_FOUND" ]; then
        DTB_NAME="$(basename "$DTB_FOUND")"
        if [ ! -f "/boot/dtb/${DTB_NAME}" ]; then
            echo "Copying board DTB to /boot/dtb/: ${DTB_NAME}"
            mkdir -p /boot/dtb
            cp "$DTB_FOUND" "/boot/dtb/${DTB_NAME}"
        else
            echo "Board DTB already present in /boot/dtb/: ${DTB_NAME}"
        fi
    else
        echo "WARNING: No matching DTB found in /boot/ for compatible '${BOARD_COMPAT}'"
    fi

    /opt/nvidia/jetson-io/config-by-hardware.py -n 2="Camera IMX219 Dual" 2>&1
    echo "=== config-by-hardware.py exit code: $? ==="
}

setup_etc_hosts() {
    cat >/etc/hosts <<EOL
127.0.0.1	localhost
127.0.0.1	$(cat /etc/hostname) $(cat /etc/hostname).local

# The following lines are desirable for IPv6 capable hosts
::1     ip6-localhost ip6-loopback
fe00::0 ip6-localnet
ff00::0 ip6-mcastprefix
ff02::1 ip6-allnodes
ff02::2 ip6-allrouters
EOL
}

store_event() {
    type=$1
    now=$(date +%s%N)
    # collect event
    echo "{\"type\": \"${type}\", \"stamp\": ${now}}" > "${EVENTS_DIR}/${now}.json"
}

install_wifi_driver() {
    # Install RTL8821CU WiFi driver if the module exists
    WIFI_MODULE="/lib/modules/$(uname -r)/extra/8821cu.ko"
    if [ -f "$WIFI_MODULE" ]; then
        echo "Installing RTL8821CU WiFi driver..."
        depmod -a
        modprobe 8821cu
        echo "8821cu" >> /etc/modules-load.d/8821cu.conf
        echo "RTL8821CU WiFi driver installed successfully"
    else
        echo "RTL8821CU WiFi driver module not found at $WIFI_MODULE, skipping..."
    fi
}

run_on_first_boot() {
    echo "Setting up the robot for its first ever boot..."

    # install WiFi driver early (before any steps that might need internet)
    install_wifi_driver

    # setup /etc/hosts
    echo "Setting up the environment..."
    setup_etc_hosts

    # activate `booting` service
    cp /etc/avahi/services/dt.booting.service.disabled /etc/avahi/services/dt.booting.service

    enable_cameras

    # resize root partition to fill the storage device
    safe_grow_rootfs

    # FIXME: this sanitizes files passed to it, but we are not passing any files to it
    dt-sanitize-files

    # sudo without a password
    echo "duckie ALL=(ALL) NOPASSWD:ALL" | tee -a /etc/sudoers

    # add "Duckietown Front Bumper" to the device tree
    # dtc -I dts -O dtb -@ -o /boot/duckietown_front_bumper_2_v1.dtbo /boot/duckietown_front_bumper_2_v1.dts
    # /opt/nvidia/jetson-io/config-by-hardware.py -n "Duckietown Front Bumper 2 V1"

    # setup ssh access
    echo "Setting up ssh..."
    mkdir -p /home/duckie/.ssh
    touch /home/duckie/.ssh/authorized_keys
    echo "ssh-rsa  DT2018key" | tee -a /home/duckie/.ssh/authorized_keys
    chmod 755 /home/duckie
    chmod 700 /home/duckie/.ssh
    chmod 600 /home/duckie/.ssh/authorized_keys
    chown -R duckie:duckie /home/duckie

    # add user `duckie` to the `root` group
    adduser duckie root

    # setup docker
    echo "Adding the user to the docker group..."
    adduser duckie docker

    # store the MAC addresses for future reference
    echo "Storing debug information..."
    cp /proc/*info /data/proc || true
    cat /sys/class/net/en*/address > /data/stats/MAC/ethernet 2>/dev/null || true
    cat /sys/class/net/wlan0/address > /data/stats/MAC/wlan0 2>/dev/null || true
    cp /etc/nv_tegra_release /data/stats/os-release || true

    # make sure the user owns its folders
    echo "Changing the ownership of the user directories..."
    chown -R 1000:1000 /data /code
    chmod -R 775 /data /code

    # create swap
    # echo "Setting up swap..."
    # dd if=/dev/zero of=/swap0 bs=1M count=2048
    # chmod 0600 /swap0
    # mkswap /swap0
    # echo "/swap0 swap swap" >>/etc/fstab
    # swapon -a

    # create tmpfs of size = 75% of the total memory
    PHYMEM_SIZE=$(free --mega | awk '/^Mem:/{print $2}')
    TMPFS_SIZE=$(python3 -c "print(int(0.75 * ${PHYMEM_SIZE}))")
    echo "tmpfs /data/ramdisk tmpfs  defaults,noatime,nosuid,nodev,noexec,mode=0777,size=${TMPFS_SIZE}M 0 0" >> /etc/fstab

    # reload systemctl and restart docker
    systemctl daemon-reload
    # systemctl enable docker
    systemctl restart docker

    while ! timeout --signal=INT 5s docker ps; do
        echo 'Waiting for Docker to start...'
        sleep 2
    done

    # disable ZRAM
    systemctl disable nvzramconfig

    # run customizable first-boot script
    dt-init-first-boot

    echo "Setting up the containers..."
    dt-autoboot

    # mark event
    store_event "first_boot"

    # collect usage stats
    mkdir -p "${USAGE_DIR}/disk_image"
    mkdir -p "${USAGE_DIR}/init_sd_card"
    cp /data/stats/disk_image/build.json "${USAGE_DIR}/disk_image/$(date +%s%N).json"
    cp /data/stats/init_sd_card/build.json "${USAGE_DIR}/init_sd_card/$(date +%s%N).json"

    echo "Setting up completed!"
}

run_on_every_boot() {
    echo "Setting up the robot for this boot..."

    # activate `booting` service
    cp /etc/avahi/services/dt.booting.service.disabled /etc/avahi/services/dt.booting.service

    # setup /etc/hosts
    setup_etc_hosts

    # set i2c bus clock rate to 400kHz (guard against boards where i2c-1 is absent)
    if [ -w /sys/bus/i2c/devices/i2c-1/bus_clk_rate ]; then
        echo 400000 > /sys/bus/i2c/devices/i2c-1/bus_clk_rate
    else
        echo "WARNING: /sys/bus/i2c/devices/i2c-1/bus_clk_rate not writable, skipping"
    fi

    # run customizable any-boot script
    dt-init-any-boot

    # remove `booting` service
    rm -f /etc/avahi/services/dt.booting.service

    # get robot_type
    if [ ${#ROBOT_TYPE} -le 0 ]; then
        if [ -f "${ROBOT_TYPE_FILE}" ]; then
            ROBOT_TYPE=$(cat "${ROBOT_TYPE_FILE}")
        else
            ROBOT_TYPE="duckiebot"
        fi
    fi

    # get robot_hardware
    if [ ${#ROBOT_HARDWARE} -le 0 ]; then
        if [ -f "${ROBOT_HARDWARE_FILE}" ]; then
            ROBOT_HARDWARE=$(cat "${ROBOT_HARDWARE_FILE}")
        else
            ROBOT_HARDWARE="__NOTSET__"
        fi
    fi

    export JETSON_MODEL_NAME="JETSON_ORIN_NANO"

    echo "Robot type: ${ROBOT_TYPE}"
    echo "Robot hardware: ${ROBOT_HARDWARE}"

    # Enable GPIOs outputs using pinmux (https://github.com/NVIDIA/jetson-gpio/issues/120)
    if [ $ROBOT_HARDWARE == "jetson_orin_nano" ]; then
        echo "Setting up pinmux for GPIO outputs..."
        chmod +x /usr/local/bin/pinmux_setup.py
        /usr/local/bin/pinmux_setup.py
    fi

    # set HUT pin to HIGH (NVidia-Jetson-orin-based robots only)
    if [ $ROBOT_TYPE == "duckiebot" ] && [ $ROBOT_HARDWARE == "jetson_orin_nano" ]; then
        # TODO: set pin #29 (`GPIO.BOARD` numbering) to high. 
        chmod +x /usr/local/bin/set_gpio.py
        /usr/local/bin/set_gpio.py
        echo "HUT pin set to HIGH"
    else
        echo "HUT pin not set to HIGH"
    fi

    # launch triggers handlers
    dt-serve-triggers

    # mark event
    store_event "boot"

    echo "Setting up completed!"
}

FIRST_BOOT_EVIDENCE_FILE="/boot/dt.first.boot.evidence"
if test -f "$FIRST_BOOT_EVIDENCE_FILE"; then
    echo "$FIRST_BOOT_EVIDENCE_FILE exists so we assume this is not the first boot!"
    run_on_every_boot 2>&1 | tee /data/logs/this_boot_init.log
else
    echo "$FIRST_BOOT_EVIDENCE_FILE does not exist so we assume this is the first boot!"
    run_on_first_boot 2>&1 | tee /data/logs/first_boot_init.log
    touch "$FIRST_BOOT_EVIDENCE_FILE"
    sync
    reboot
fi
